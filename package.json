{
  "name": "diploma",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node node_modules/concurrently/dist/bin/concurrently.js \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node node_modules/nodemon/bin/nodemon.js server/server.js",
    "dev:client": "node node_modules/vite/bin/vite.js --config client/vite.config.js",
    "build": "npm run build:client",
    "build:client": "node node_modules/vite/bin/vite.js build --config client/vite.config.js",
    "preview:client": "node node_modules/vite/bin/vite.js preview --config client/vite.config.js",
    "start": "node server/server.js",
    "seed:animals": "node server/scripts/seedAnimals.js",
    "seed:demo": "node server/scripts/seedDemoData.js",
    "check:regression": "node server/scripts/runRegressionCheck.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.11",
    "vite": "^4.5.14"
  }
}
